{
  "name": "clean_architecture_template",
  "workspaces": [
    "domain",
    "apps/*"
  ],
  "type": "module",
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "scripts": {
    "fe": "yarn workspaces foreach -vvpA --exclude '.'",
    "fet": "yarn fe --topological",
    "test": "yarn fe --exclude 'packages/templates/*' run test --run --clearScreen false",
    "build": "yarn fet --exclude 'packages/templates/*' run build"
  }
}
